# =============================================================================
# PRODUCTION ENVIRONMENT - docker-compose.prod.yml
# =============================================================================
# Copy this file and fill in your actual values
# Usage: docker compose -f docker-compose.prod.yml up -d
# =============================================================================

# =============================================================================
# STORAGE - MinIO
# =============================================================================
MINIO_ROOT_USER=your_minio_user
MINIO_ROOT_PASSWORD=your_minio_password

# Milvus MinIO (separate instance)
MINIO_ACCESS_KEY_ID=your_milvus_minio_access_key
MINIO_SECRET_ACCESS_KEY=your_milvus_minio_secret_key

# =============================================================================
# STORAGE - PostgreSQL
# =============================================================================
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=islamic-library-db

# Master Server DB connection
DB_HOST=books-db
DB_PORT=5432
DB_USERNAME=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_DATABASE=islamic-library-db
USERS_DATABASE_URI=postgresql://your_postgres_user:your_postgres_password@books-db:5432/islamic-library-db

# =============================================================================
# STORAGE - Milvus
# =============================================================================
COMMON_SECURITY_DEFAULTROOTPASSWORD=your_milvus_root_password
QUERYNODE_MMAP_VECTORFIELD=true
QUERYNODE_MMAP_VECTORINDEX=true
QUERYNODE_MMAP_SCALARFIELD=true
QUERYNODE_MMAP_SCALARINDEX=true
MILVUS_TOKEN=root:your_milvus_root_password

# =============================================================================
# RAG PIPELINE - API Keys
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key
DEEPINFRA_API_KEY=your_deepinfra_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key

# =============================================================================
# RAG PIPELINE - Service Configuration
# =============================================================================
GEMINI_OPTIMIZE_MODEL=gemini-2.5-flash-lite
GEMINI_ASK_MODEL=gemini-2.5-flash
SYSTEM_INSTRUCTION_PATH=system_instruction.txt
EMBEDDING_MODEL=BAAI/bge-m3-multi
MAX_TEXTS_PER_REQUEST=10
MAX_TEXT_LENGTH=8000
MAX_EMBEDDINGS_PER_REQUEST=10
MAX_SEARCH_K=100
MAX_QUERIES_PER_REQUEST=10
MAX_QUERY_LENGTH=1000

# =============================================================================
# COMMON SETTINGS
# =============================================================================
LOG_LEVEL=INFO
REQUEST_TIMEOUT=120
ALLOWED_ORIGINS=*

# =============================================================================
# CLIENT (Next.js)
# =============================================================================
# These are baked into the client at build time
NEXT_PUBLIC_API_BASE_URL=/gateway
NEXT_PUBLIC_MASTER_BASE_URL=/master

# Neon Authentication
NEON_AUTH_BASE_URL=your_neon_auth_base_url
NEON_AUTH_COOKIE_SECRET=your_neon_auth_cookie_secret

# Azure Translate
AZURE_TRANSLATE_API_KEY=your_azure_translate_api_key
AZURE_TRANSLATE_REGION=your_azure_region
AZURE_TRANSLATE_BASE_URL=your_azure_translate_base_url
